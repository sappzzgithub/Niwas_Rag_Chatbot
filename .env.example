# ─────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is listed in .gitignore.
# ─────────────────────────────────────────────

# ── Groq API (required) ──────────────────────
# Get your free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Vision model (Groq multimodal) ───────────
VISION_PROVIDER=groq
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── LLM for answer generation ─────────────────
# "groq" = cloud (fast, rate limited on free tier)
# "ollama" = local (no rate limits, slower)
LLM_PROVIDER=groq
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# ── Embeddings (runs locally, no API key needed) ──
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# ── Ollama (only needed if LLM_PROVIDER=ollama) ───
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=mistral:7b-instruct-q4_0

# ── Optional tuning ───────────────────────────
LLM_INTER_QUESTION_DELAY=30
LOG_LEVEL=INFO
